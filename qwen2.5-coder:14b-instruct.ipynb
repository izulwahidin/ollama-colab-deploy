#!/usr/bin/env python3
"""
Ollama Backend Setup Script
Automatically deploys an Ollama LLM backend with secure Cloudflare tunnel access.

Features:
- Modular, error-resilient setup
- Comprehensive logging with progress tracking
- Configurable model and networking parameters
- Optional webhook notifications
- Retry logic with exponential backoff
"""

import subprocess
import os
import sys
import time
import re
import urllib.request
import json
import logging
from dataclasses import dataclass
from typing import Optional
from pathlib import Path

# ============================================================================
# CONFIGURATION
# ============================================================================

@dataclass
class Config:
    """Setup configuration."""
    ollama_host: str = "0.0.0.0:11434"
    ollama_port: int = 11434
    model_name: str = "qwen2.5-coder:14b-instruct"
    cloudflared_url: str = "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64"
    webhook_url: Optional[str] = None  # Set to enable Discord/Slack notifications
    tunnel_timeout: int = 30  # Seconds to wait for tunnel URL
    max_tunnel_retries: int = 5


# ============================================================================
# LOGGING SETUP
# ============================================================================

def setup_logging(level=logging.INFO) -> logging.Logger:
    """Configure colored logging with timestamps."""
    logger = logging.getLogger("OllamaSetup")
    logger.setLevel(level)
    
    if not logger.handlers:
        handler = logging.StreamHandler(sys.stdout)
        formatter = logging.Formatter(
            "%(asctime)s | %(levelname)-8s | %(message)s",
            datefmt="%H:%M:%S"
        )
        handler.setFormatter(formatter)
        logger.addHandler(handler)
    
    return logger


logger = setup_logging()


# ============================================================================
# SYSTEM SETUP
# ============================================================================

def install_system_dependencies(logger: logging.Logger) -> bool:
    """Install required system packages."""
    logger.info("Installing system dependencies (zstd)...")
    try:
        subprocess.run(
            "sudo apt-get update -y",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=60
        )
        subprocess.run(
            "sudo apt-get install -y zstd",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=60
        )
        logger.info("✅ System dependencies installed")
        return True
    except subprocess.TimeoutExpired:
        logger.error("❌ Timeout installing system dependencies")
        return False
    except Exception as e:
        logger.error(f"❌ Failed to install dependencies: {e}")
        return False


def install_ollama(logger: logging.Logger) -> bool:
    """Install Ollama from official source."""
    logger.info("Installing Ollama...")
    try:
        result = subprocess.run(
            "curl -fsSL https://ollama.com/install.sh | sh",
            shell=True,
            capture_output=True,
            text=True,
            timeout=120
        )
        if result.returncode != 0:
            logger.error(f"❌ Ollama installation failed: {result.stderr}")
            return False
        logger.info("✅ Ollama installed successfully")
        return True
    except subprocess.TimeoutExpired:
        logger.error("❌ Timeout during Ollama installation")
        return False
    except Exception as e:
        logger.error(f"❌ Installation error: {e}")
        return False


def verify_ollama_executable(executable_path: str, logger: logging.Logger) -> bool:
    """Verify Ollama executable exists and is accessible."""
    if not os.path.exists(executable_path):
        logger.error(f"❌ Ollama executable not found at {executable_path}")
        return False
    if not os.access(executable_path, os.X_OK):
        logger.error(f"❌ Ollama executable exists but is not executable")
        return False
    logger.info(f"✅ Ollama executable verified at {executable_path}")
    return True


def start_ollama_server(executable_path: str, logger: logging.Logger) -> bool:
    """Start Ollama server with proper environment configuration."""
    logger.info("Starting Ollama server...")
    try:
        ollama_env = os.environ.copy()
        ollama_env["OLLAMA_HOST"] = Config.ollama_host
        ollama_env["PATH"] = ollama_env.get("PATH", "") + ":/usr/local/bin"
        
        subprocess.Popen(
            [executable_path, "serve"],
            env=ollama_env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        time.sleep(5)  # Wait for server to initialize
        logger.info(f"✅ Ollama server started on {Config.ollama_host}")
        return True
    except Exception as e:
        logger.error(f"❌ Failed to start Ollama server: {e}")
        return False


# ============================================================================
# MODEL MANAGEMENT
# ============================================================================

def pull_model(executable_path: str, model_name: str, logger: logging.Logger) -> bool:
    """Download and cache the target model."""
    logger.info(f"Pulling model: {model_name}")
    try:
        result = subprocess.run(
            [executable_path, "pull", model_name],
            capture_output=True,
            text=True,
            timeout=600  # 10 minutes
        )
        if result.returncode != 0:
            logger.error(f"❌ Model pull failed: {result.stderr}")
            return False
        logger.info(f"✅ Model '{model_name}' ready")
        return True
    except subprocess.TimeoutExpired:
        logger.error(f"❌ Model pull timed out (exceeded 10 minutes)")
        return False
    except Exception as e:
        logger.error(f"❌ Model pull error: {e}")
        return False


# ============================================================================
# TUNNEL SETUP
# ============================================================================

def download_cloudflared(url: str, logger: logging.Logger) -> bool:
    """Download the latest cloudflared binary."""
    logger.info("Downloading cloudflared...")
    try:
        subprocess.run(
            f"curl -L {url} -o cloudflared",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=60
        )
        subprocess.run(
            "chmod +x cloudflared",
            shell=True,
            timeout=10
        )
        logger.info("✅ cloudflared ready")
        return True
    except subprocess.TimeoutExpired:
        logger.error("❌ Timeout downloading cloudflared")
        return False
    except Exception as e:
        logger.error(f"❌ Failed to setup cloudflared: {e}")
        return False


def establish_tunnel(logger: logging.Logger) -> Optional[str]:
    """
    Establish Cloudflare tunnel with retry logic and timeout handling.
    Returns public URL or None if failed.
    """
    logger.info("Establishing secure tunnel...")
    
    for attempt in range(1, Config.max_tunnel_retries + 1):
        logger.info(f"Tunnel attempt {attempt}/{Config.max_tunnel_retries}")
        
        try:
            tunnel_proc = subprocess.Popen(
                ["./cloudflared", "tunnel", "--url", f"http://localhost:{Config.ollama_port}"],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True
            )
            
            public_url = None
            output_lines = []
            start_time = time.time()
            
            # Monitor output with timeout
            while time.time() - start_time < Config.tunnel_timeout:
                line = tunnel_proc.stdout.readline()
                if not line:
                    time.sleep(0.1)
                    continue
                
                output_lines.append(line.strip())
                logger.debug(f"Tunnel output: {line.strip()}")
                
                if "trycloudflare.com" in line:
                    match = re.search(r'https://[a-zA-Z0-9-]+\.trycloudflare\.com', line)
                    if match:
                        public_url = match.group(0)
                        tunnel_proc.terminate()  # Stop listening once URL found
                        logger.info(f"✅ Tunnel established: {public_url}")
                        return public_url
            
            # Timeout reached without finding URL
            tunnel_proc.terminate()
            logger.warning(f"❌ Tunnel timeout on attempt {attempt}")
            
        except Exception as e:
            logger.warning(f"❌ Tunnel failed on attempt {attempt}: {e}")
        
        if attempt < Config.max_tunnel_retries:
            wait_time = min(5 * attempt, 30)  # Exponential backoff, capped at 30s
            logger.info(f"Retrying in {wait_time}s...")
            time.sleep(wait_time)
    
    logger.error("❌ Failed to establish tunnel after all retries")
    return None


# ============================================================================
# NOTIFICATIONS
# ============================================================================

def send_webhook_notification(public_url: str, logger: logging.Logger) -> bool:
    """Send tunnel URL to webhook (Discord, Slack, n8n, etc.)."""
    if not Config.webhook_url:
        logger.debug("Webhook not configured, skipping notification")
        return True
    
    logger.info("Sending webhook notification...")
    try:
        payload = {
            "content": f"🚀 Ollama Backend Ready!\n{public_url}/v1",
            "url": public_url
        }
        data = json.dumps(payload).encode('utf-8')
        req = urllib.request.Request(
            Config.webhook_url,
            data=data,
            headers={'Content-Type': 'application/json'}
        )
        
        with urllib.request.urlopen(req, timeout=10) as response:
            logger.info("✅ Webhook sent successfully")
            return True
    except Exception as e:
        logger.warning(f"⚠️  Failed to send webhook: {e}")
        return False


# ============================================================================
# MAIN ORCHESTRATION
# ============================================================================

def main():
    """Main setup orchestration."""
    logger.info("=" * 60)
    logger.info("OLLAMA BACKEND DEPLOYMENT")
    logger.info("=" * 60)
    
    ollama_path = "/usr/local/bin/ollama"
    
    # Step 1: System setup
    logger.info("\n[Step 1/5] System Setup")
    if not install_system_dependencies(logger):
        logger.critical("Cannot proceed without system dependencies")
        return 1
    if not install_ollama(logger):
        logger.critical("Cannot proceed without Ollama")
        return 1
    if not verify_ollama_executable(ollama_path, logger):
        logger.critical("Ollama executable verification failed")
        return 1
    
    # Step 2: Start server
    logger.info("\n[Step 2/5] Server Initialization")
    if not start_ollama_server(ollama_path, logger):
        logger.critical("Failed to start Ollama server")
        return 1
    
    # Step 3: Pull model
    logger.info("\n[Step 3/5] Model Preparation")
    if not pull_model(ollama_path, Config.model_name, logger):
        logger.error("Model preparation failed (continuing anyway)")
    
    # Step 4: Tunnel setup
    logger.info("\n[Step 4/5] Tunnel Deployment")
    if not download_cloudflared(Config.cloudflared_url, logger):
        logger.critical("Failed to setup cloudflared")
        return 1
    
    public_url = establish_tunnel(logger)
    if not public_url:
        logger.critical("Failed to establish tunnel")
        return 1
    
    # Step 5: Notifications
    logger.info("\n[Step 5/5] Notifications")
    send_webhook_notification(public_url, logger)
    
    # Success summary
    logger.info("\n" + "=" * 60)
    logger.info("🎉 DEPLOYMENT COMPLETE")
    logger.info("=" * 60)
    logger.info(f"🌐 Public URL: {public_url}")
    logger.info(f"📝 API Endpoint: {public_url}/v1")
    logger.info(f"🤖 Model: {Config.model_name}")
    logger.info("=" * 60 + "\n")
    
    # Keep the tunnel alive
    try:
        while True:
            time.sleep(60)
    except KeyboardInterrupt:
        logger.info("\nShutdown signal received. Cleaning up...")
        return 0


if __name__ == "__main__":
    sys.exit(main())
